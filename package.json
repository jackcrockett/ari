{
  "name": "aventa-race-intelligence",
  "version": "0.2.0",
  "description": "Aventa Race Intelligence - Premium sim racing overlays",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "kill": "taskkill /F /IM electron.exe /T 2>nul & taskkill /F /IM ari_bridge.exe /T 2>nul & echo Done",
    "install-deps": "npm install"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.aventa.ari",
    "productName": "ARI",
    "icon": "icon.ico",
    "win": {
      "icon": "icon.ico",
      "target": "nsis"
    }
  }
}